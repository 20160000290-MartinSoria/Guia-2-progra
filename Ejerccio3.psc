Algoritmo sin_titulo
	Definir letra Como Caracter
	Escribir Sin Saltar "Dijite una letra:"
	Leer letra
	Segun letra Hacer
		"A" o "a":
			Escribir "EXELENTE"
		"B"o "B":
			Escribir "BUENO"
		"C"o "c":
			Escribir "REGULAR"
		"D" o "d":
			Escribir "DEFICIENTE"
		"F" o "f":
			Escribir "REPREVADO"
		De Otro Modo:
			Escribir "Letra no valida"
	FinSegun
FinAlgoritmo
